# Frontend environment variables
# Copy to .env in this folder.
#
# Development: omit VITE_API_URL (or leave empty) so requests use the Vite dev server
# proxy to the backend — same origin, no CORS issues.
# Production: set VITE_API_URL to your deployed API origin (no trailing slash).

# VITE_API_URL=https://your-api.example.com
VITE_APP_NAME=ScholARA
VITE_APP_VERSION=1.0.0
