# ============================================================
# ScholARA — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- App Config ---
APP_NAME=ScholARA
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# --- Server ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173

# --- Security (CHANGE THESE IN PRODUCTION) ---
SECRET_KEY=your-super-secret-jwt-key-change-this-to-random-string-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Database ---
DATABASE_URL=sqlite:///./scholara.db

# --- LLM Config ---
# Options: "ollama" | "huggingface"
LLM_PROVIDER=ollama

# Ollama settings (local — install from https://ollama.ai)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
# Other good free options: phi3, mistral, gemma2

# HuggingFace settings (fallback — free tier)
HUGGINGFACE_API_TOKEN=hf_your_token_here
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# --- Embedding Model ---
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# --- Vector DB ---
FAISS_INDEX_PATH=./vector_db/faiss_index
VECTOR_DB_TYPE=faiss

# --- Document Processing ---
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RETRIEVAL=5

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
